{
  "manifest_version": 3,
  "name": "Limited Media Tracker",
  "version": "2026.3.1",
  "description": "Track and categorize HTTP requests (media-focused)",
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "limitedmediatracker@mgatelabs.com",
      "strict_min_version": "102.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "96": "icon-96.png"
  },
  "action": {
    "default_popup": "popup-launcher.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "96": "icon-96.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "window.html",
        "window.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
